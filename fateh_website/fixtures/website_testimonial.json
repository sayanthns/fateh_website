    "role_ar": "\u0645\u062f\u064a\u0631\u0629 \u0627\u0644\u0634\u0624\u0648\u0646 \u0627\u0644\u0645\u0627\u0644\u064a\u0629",
    "company": "Gulf Goods Trading",
    "company_ar": "\u062a\u062c\u0627\u0631\u0629 \u0628\u0636\u0627\u0626\u0639 \u0627\u0644\u062e\u0644\u064a\u062c",
    "quote": "We migrated from spreadsheets to Fateh ERP in just 3 weeks. The multi-warehouse inventory tracking alone saved us hours every day. Best investment we've made for our business.",
    "quote_ar": "\u0627\u0646\u062a\u0642\u0644\u0646\u0627 \u0645\u0646 \u062c\u062f\u0627\u0648\u0644 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0625\u0644\u0649 \u0646\u0638\u0627\u0645 \u0641\u0627\u062a\u062d \u0641\u064a 3 \u0623\u0633\u0627\u0628\u064a\u0639 \u0641\u0642\u0637. \u062a\u062a\u0628\u0639 \u0627\u0644\u0645\u062e\u0632\u0648\u0646 \u0645\u062a\u0639\u062f\u062f \u0627\u0644\u0645\u0633\u062a\u0648\u062f\u0639\u0627\u062a \u0648\u062d\u062f\u0647 \u0648\u0641\u0631 \u0644\u0646\u0627 \u0633\u0627\u0639\u0627\u062a \u0643\u0644 \u064a\u0648\u0645. \u0623\u0641\u0636\u0644 \u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0642\u0645\u0646\u0627 \u0628\u0647 \u0644\u0623\u0639\u0645\u0627\u0644\u0646\u0627.",
    "rating": 5,
