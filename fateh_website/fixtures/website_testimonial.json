    "role_ar": "\u0645\u062f\u064a\u0631 \u0627\u0644\u0639\u0645\u0644\u064a\u0627\u062a",
    "company": "Al-Qahtani Group",
    "company_ar": "\u0645\u062c\u0645\u0648\u0639\u0629 \u0627\u0644\u0642\u062d\u0637\u0627\u0646\u064a",
    "quote": "Managing procurement across multiple suppliers used to be a nightmare. Fateh ERP's purchase management and supplier tracking gave us complete visibility and control over costs.",
    "quote_ar": "\u0643\u0627\u0646\u062a \u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u0645\u0634\u062a\u0631\u064a\u0627\u062a \u0639\u0628\u0631 \u0645\u0648\u0631\u062f\u064a\u0646 \u0645\u062a\u0639\u062f\u062f\u064a\u0646 \u0643\u0627\u0628\u0648\u0633\u0627\u064b. \u0645\u0646\u062d\u0646\u0627 \u0646\u0638\u0627\u0645 \u0641\u0627\u062a\u062d \u0644\u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u0645\u0634\u062a\u0631\u064a\u0627\u062a \u0648\u062a\u062a\u0628\u0639 \u0627\u0644\u0645\u0648\u0631\u062f\u064a\u0646 \u0631\u0624\u064a\u0629 \u0643\u0627\u0645\u0644\u0629 \u0648\u062a\u062d\u0643\u0645\u0627\u064b \u0641\u064a \u0627\u0644\u062a\u0643\u0627\u0644\u064a\u0641.",
