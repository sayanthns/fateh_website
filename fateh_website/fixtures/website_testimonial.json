    "company_ar": "\u0634\u0631\u0643\u0629 \u0627\u0644\u062f\u0648\u0633\u0631\u064a \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629",
    "quote": "Fateh ERP transformed how we manage our trading operations. ZATCA compliance was seamless, and the support team is responsive and knowledgeable. We went live in just two weeks.",
    "quote_ar": "\u063a\u064a\u0651\u0631 \u0646\u0638\u0627\u0645 \u0641\u0627\u062a\u062d \u0637\u0631\u064a\u0642\u0629 \u0625\u062f\u0627\u0631\u062a\u0646\u0627 \u0644\u0639\u0645\u0644\u064a\u0627\u062a\u0646\u0627 \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629. \u0643\u0627\u0646 \u0627\u0644\u0627\u0645\u062a\u062b\u0627\u0644 \u0644\u0647\u064a\u0626\u0629 \u0627\u0644\u0632\u0643\u0627\u0629 \u0633\u0644\u0633\u0627\u064b\u060c \u0648\u0641\u0631\u064a\u0642 \u0627\u0644\u062f\u0639\u0645 \u0645\u062a\u062c\u0627\u0648\u0628 \u0648\u0645\u062a\u0645\u0643\u0646. \u0628\u062f\u0623\u0646\u0627 \u0627\u0644\u0639\u0645\u0644 \u0641\u064a \u0623\u0633\u0628\u0648\u0639\u064a\u0646 \u0641\u0642\u0637.",
    "rating": 5,
